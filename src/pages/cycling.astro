---
import BaseLayout from '../layouts/BaseLayout.astro';
import WoodPanel from '../components/WoodPanel.astro';
---

<BaseLayout title="Cycling" description="Cycling results and stats for Vedran Chichov.">
  <section class="container stub">
    <h1>Cycling</h1>
    <WoodPanel>
      <p class="pixel-label">🚲 Under construction</p>
      <p>Race results and stats from ProCyclingStats will roll in here soon.</p>
    </WoodPanel>
  </section>
</BaseLayout>

<style>
  .stub {
    padding-block: clamp(2rem, 6vw, 3.5rem);
    max-width: 720px;
  }
  .pixel-label {
    color: var(--accent-strong);
  }
</style>
