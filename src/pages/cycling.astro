---
import BaseLayout from '../layouts/BaseLayout.astro';
import WoodPanel from '../components/WoodPanel.astro';
import PixelButton from '../components/PixelButton.astro';
import data from '../data/cycling.json';

const { rider, results, source, generatedAt } = data;

// Age from birthdate.
function ageFrom(iso: string | null): number | null {
  if (!iso) return null;
  const b = new Date(iso);
  const now = new Date();
  let age = now.getFullYear() - b.getFullYear();
  const m = now.getMonth() - b.getMonth();
  if (m < 0 || (m === 0 && now.getDate() < b.getDate())) age--;
  return age;
}
const age = ageFrom(rider.birthdate);

function fmtDate(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}

function ordinal(n: number): string {
  const s = ['th', 'st', 'nd', 'rd'];
  const v = n % 100;
  return n + (s[(v - 20) % 10] ?? s[v] ?? s[0]);
}

type Result = (typeof results)[number];

// Palmarès = ranked results (drop DNFs), best placing first. Focus on the strong ones.
const ranked = results.filter((r): r is Result & { rank: number } => r.rank != null);
const highlights = [...ranked]
  .filter((r) => r.rank <= 10)
  .sort((a, b) => a.rank - b.rank || (b.date ?? '').localeCompare(a.date ?? ''));

const medalClass = (rank: number) =>
  rank === 1 ? 'gold' : rank === 2 ? 'silver' : rank === 3 ? 'bronze' : 'plain';
---

<BaseLayout
  title="Cycling"
  description="Race results and career highlights for Vedran Chichov, from ProCyclingStats."
>
  <section class="container cycling">
    <header class="page-head">
      <p class="eyebrow pixel-label">On the bike</p>
      <h1>Cycling</h1>
      <p class="lede">
        I race on the road — a time-trial rider at heart. Here are my career highlights and results,
        pulled from ProCyclingStats.
      </p>
    </header>

    <WoodPanel class="profile">
      <dl class="profile-grid">
        <div><dt class="pixel-label">Country</dt><dd>{rider.nationalityName ?? '—'}</dd></div>
        {
          age !== null && (
            <div>
              <>
                <dt class="pixel-label">Age</dt>
                <dd>{age}</dd>
              </>
            </div>
          )
        }
        {
          rider.team?.name && (
            <div>
              <>
                <dt class="pixel-label">Team</dt>
                <dd>{rider.team.name}</dd>
              </>
            </div>
          )
        }
      </dl>
      <PixelButton href={source} variant="ghost">Full profile on PCS</PixelButton>
    </WoodPanel>

    {
      highlights.length > 0 && (
        <section class="block" aria-labelledby="palmares-h">
          <h2 id="palmares-h">Career highlights</h2>
          <ul class="palmares">
            {highlights.map((r) => (
              <li>
                <WoodPanel as="article" class="hl">
                  <span class:list={['medal', medalClass(r.rank)]} aria-hidden="true">
                    {r.rank}
                  </span>
                  <div class="hl-body">
                    <p class="hl-place pixel-label">{ordinal(r.rank)} place</p>
                    <h3 class="hl-race">
                      {r.url ? (
                        <a href={r.url} target="_blank" rel="noopener">
                          {r.race}
                        </a>
                      ) : (
                        r.race
                      )}
                    </h3>
                    <p class="hl-meta">
                      {fmtDate(r.date)}
                      {r.raceClass && <span class="tag pixel-label">{r.raceClass}</span>}
                    </p>
                  </div>
                </WoodPanel>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="block" aria-labelledby="results-h">
      <h2 id="results-h">All results</h2>
      <WoodPanel class="table-wrap">
        <table class="results">
          <thead>
            <tr>
              <th scope="col">Date</th>
              <th scope="col">Race</th>
              <th scope="col">Class</th>
              <th scope="col" class="num">Result</th>
            </tr>
          </thead>
          <tbody>
            {
              results.map((r) => (
                <tr>
                  <td data-label="Date">{fmtDate(r.date)}</td>
                  <td data-label="Race">
                    {r.url ? (
                      <a href={r.url} target="_blank" rel="noopener">
                        {r.race}
                      </a>
                    ) : (
                      r.race
                    )}
                  </td>
                  <td data-label="Class">{r.raceClass ?? '—'}</td>
                  <td data-label="Result" class="num">
                    {r.rank != null ? ordinal(r.rank) : 'DNF'}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </WoodPanel>
    </section>

    <p class="synced pixel-label">
      Synced from ProCyclingStats · updated {fmtDate(generatedAt.slice(0, 10))}
    </p>
  </section>
</BaseLayout>

<style>
  .cycling {
    padding-block: clamp(2rem, 6vw, 3.5rem);
  }
  .page-head {
    max-width: 60ch;
    margin-bottom: 1.75rem;
  }
  .eyebrow {
    color: var(--accent-strong);
    margin: 0 0 0.5rem;
  }
  .page-head h1 {
    margin: 0 0 0.5rem;
  }
  .lede {
    margin: 0;
    color: var(--text-muted);
  }

  .profile {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .profile-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin: 0;
  }
  .profile-grid dt {
    color: var(--text-muted);
    margin-bottom: 0.15rem;
  }
  .profile-grid dd {
    margin: 0;
    font-size: 1.1rem;
  }

  .block {
    margin-top: 2.5rem;
  }
  .block h2 {
    margin-bottom: 1rem;
  }

  .palmares {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .hl {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 100%;
  }
  .medal {
    flex: none;
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    font-family: var(--font-num);
    font-size: 1.7rem;
    color: var(--wood-dark);
    background: var(--surface-2);
    border: 3px solid var(--frame-dark);
    border-radius: 50%;
  }
  .medal.gold {
    background: #f2c94c;
  }
  .medal.silver {
    background: #d5d8dc;
  }
  .medal.bronze {
    background: #d79a63;
  }
  .hl-body {
    min-width: 0;
  }
  .hl-place {
    margin: 0 0 0.15rem;
    color: var(--accent-strong);
  }
  .hl-race {
    margin: 0 0 0.35rem;
    font-size: 1.05rem;
  }
  .hl-race a {
    color: var(--text);
    text-decoration: none;
  }
  .hl-race a:hover {
    color: var(--link);
  }
  .hl-meta {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .tag {
    background: var(--surface-2);
    border: 2px solid var(--frame);
    border-radius: 2px;
    padding: 0.1rem 0.35rem;
  }

  .table-wrap {
    overflow-x: auto;
  }
  .results {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.98rem;
  }
  .results th,
  .results td {
    text-align: left;
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid var(--surface-2);
  }
  .results thead th {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }
  .results .num {
    text-align: right;
    font-family: var(--font-num);
    font-size: 1.15rem;
  }
  .results a {
    color: var(--text);
    text-decoration: none;
  }
  .results a:hover {
    color: var(--link);
    text-decoration: underline;
  }

  .synced {
    margin-top: 2rem;
    color: var(--text-muted);
  }

  /* Stack the results table into cards on small screens. */
  @media (max-width: 560px) {
    .results thead {
      display: none;
    }
    .results,
    .results tbody,
    .results tr,
    .results td {
      display: block;
      width: 100%;
    }
    .results tr {
      margin-bottom: 0.75rem;
      border: 2px solid var(--surface-2);
      border-radius: var(--radius);
      padding: 0.25rem 0.5rem;
    }
    .results td {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      border-bottom: 1px solid var(--surface-2);
    }
    .results td::before {
      content: attr(data-label);
      font-family: var(--font-pixel);
      font-size: 0.65rem;
      text-transform: uppercase;
      color: var(--text-muted);
    }
    .results .num {
      text-align: right;
    }
  }
</style>
