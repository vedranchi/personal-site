---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { slugifyTag } from '../../../lib/format';

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );
  const tags = new Map<string, { label: string; posts: typeof posts }>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      const slug = slugifyTag(tag);
      if (!tags.has(slug)) tags.set(slug, { label: tag, posts: [] });
      tags.get(slug)!.posts.push(post);
    }
  }
  return [...tags.entries()].map(([slug, { label, posts }]) => ({
    params: { tag: slug },
    props: {
      label,
      posts: posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
    },
  }));
}) satisfies GetStaticPaths;

const { label, posts } = Astro.props;
---

<BaseLayout title={`#${label}`} description={`Posts tagged ${label}.`}>
  <section class="container tag-page">
    <header class="page-head">
      <a href="/blog" class="back pixel-label">← All posts</a>
      <h1>#{label}</h1>
      <p class="lede">{posts.length} post{posts.length === 1 ? '' : 's'} tagged “{label}”.</p>
    </header>

    <ul class="grid">
      {
        posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .tag-page {
    padding-block: clamp(2rem, 6vw, 3.5rem);
  }
  .page-head {
    margin-bottom: 2rem;
  }
  .back {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--accent-strong);
    text-decoration: none;
  }
  .back:hover {
    color: var(--link-hover);
  }
  .page-head h1 {
    margin: 0 0 0.4rem;
  }
  .lede {
    margin: 0;
    color: var(--text-muted);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
