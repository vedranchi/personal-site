---
import BaseLayout from '../layouts/BaseLayout.astro';
import WoodPanel from '../components/WoodPanel.astro';
import PixelButton from '../components/PixelButton.astro';
---

<BaseLayout title="Page not found" description="This page doesn't exist — let's get you back home.">
  <section class="container not-found">
    <WoodPanel as="div" class="panel">
      <p class="eyebrow pixel-label">404</p>
      <h1>Nothing planted here</h1>
      <p class="lede">
        This patch of the farm is empty — the page you're looking for doesn't exist or moved.
      </p>
      <div class="cta">
        <PixelButton href="/">Back to the farm</PixelButton>
        <PixelButton href="/projects" variant="ghost">See projects</PixelButton>
      </div>
    </WoodPanel>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: grid;
    place-items: center;
    min-height: 50vh;
    padding-block: clamp(2rem, 8vw, 4rem);
  }
  .panel {
    max-width: 46ch;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .eyebrow {
    color: var(--accent-strong);
    margin: 0;
  }
  h1 {
    margin: 0;
  }
  .lede {
    margin: 0;
    color: var(--text-muted);
  }
  .cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }
</style>
