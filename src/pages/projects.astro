---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import type { Project } from '../components/ProjectCard.astro';
import PixelButton from '../components/PixelButton.astro';
import { site } from '../data/site';
import data from '../data/projects.json';

const projects = data.projects as Project[];
const githubUrl = site.socials.find((s) => s.label === 'GitHub')?.href ?? 'https://github.com';
---

<BaseLayout
  title="Projects"
  description="Programming projects by Vedran Chichov, synced from GitHub."
>
  <section class="container projects-page">
    <header class="page-head">
      <p class="eyebrow pixel-label">What I've been building</p>
      <h1>Projects</h1>
      <p class="lede">
        My public repositories, pulled straight from GitHub. Click <strong>Code</strong> to dig into any
        of them.
      </p>
    </header>

    {
      projects.length > 0 ? (
        <ul class="grid">
          {projects.map((project) => (
            <li>
              <ProjectCard project={project} />
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty">No public projects to show yet — check back soon!</p>
      )
    }

    <div class="more">
      <PixelButton href={githubUrl} variant="ghost">See all on GitHub</PixelButton>
    </div>
  </section>
</BaseLayout>

<style>
  .projects-page {
    padding-block: clamp(2rem, 6vw, 3.5rem);
  }
  .page-head {
    max-width: 60ch;
    margin-bottom: 2rem;
  }
  .eyebrow {
    color: var(--accent-strong);
    margin: 0 0 0.5rem;
  }
  .page-head h1 {
    margin: 0 0 0.5rem;
  }
  .lede {
    margin: 0;
    color: var(--text-muted);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .empty {
    color: var(--text-muted);
  }
  .more {
    margin-top: 2.5rem;
  }
</style>
