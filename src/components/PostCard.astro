---
import type { CollectionEntry } from 'astro:content';
import WoodPanel from './WoodPanel.astro';
import { formatDate, slugifyTag } from '../lib/format';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post }: Props = Astro.props;
const { title, description, pubDate, tags } = post.data;
---

<WoodPanel as="article" class="post-card">
  <p class="post-date pixel-label">{formatDate(pubDate)}</p>
  <h2 class="post-title">
    <a href={`/blog/${post.id}`}>{title}</a>
  </h2>
  {description && <p class="post-desc">{description}</p>}
  {
    tags.length > 0 && (
      <ul class="post-tags">
        {tags.map((tag) => (
          <li>
            <a class="tag pixel-label" href={`/blog/tags/${slugifyTag(tag)}`}>
              #{tag}
            </a>
          </li>
        ))}
      </ul>
    )
  }
</WoodPanel>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    height: 100%;
  }
  .post-date {
    margin: 0;
    color: var(--text-muted);
  }
  .post-title {
    margin: 0;
    font-size: 1.4rem;
  }
  .post-title a {
    color: var(--text);
    text-decoration: none;
  }
  .post-title a:hover {
    color: var(--link);
  }
  .post-desc {
    margin: 0;
    color: var(--text-muted);
    flex: 1;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    margin: 0.25rem 0 0;
    padding: 0;
  }
  .tag {
    display: inline-block;
    background: var(--surface-2);
    border: 2px solid var(--frame);
    border-radius: 2px;
    padding: 0.15rem 0.4rem;
    color: var(--text-muted);
    text-decoration: none;
  }
  .tag:hover {
    color: var(--text);
    border-color: var(--accent);
  }
</style>
