---
// A chunky pixel "wooden" panel: dark outer frame + wood inner frame + hard drop shadow.
interface Props {
  as?: string;
  class?: string;
  tone?: 'default' | 'raised';
}
const { as: Tag = 'div', class: className = '', tone = 'default' }: Props = Astro.props;
---

<Tag class:list={['wood-panel', `tone-${tone}`, className]}>
  <slot />
</Tag>

<style>
  .wood-panel {
    position: relative;
    background: var(--surface);
    border: 3px solid var(--frame-dark);
    border-radius: var(--radius);
    box-shadow:
      inset 0 0 0 3px var(--frame),
      var(--pixel) var(--pixel) 0 0 var(--frame-dark);
    padding: clamp(1.1rem, 3vw, 1.75rem);
  }
  .tone-raised {
    background: var(--surface-2);
  }
</style>
