---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="footer-name">
      <span aria-hidden="true">🚲</span>
      {site.name}
    </p>
    <ul class="footer-links">
      {
        site.socials.map((s) => (
          <li>
            <a href={s.href} rel="me noopener" target="_blank">
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>
    <p class="footer-meta pixel-label">© {year} · grown with Astro</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-alt);
    border-top: 3px solid var(--frame-dark);
    margin-top: 3rem;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.5rem;
    padding-block: 1.25rem;
  }
  .footer-name {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.1rem;
  }
  .footer-links {
    display: flex;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-links a {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--link);
  }
  .footer-links a:hover {
    color: var(--link-hover);
  }
  .footer-meta {
    margin: 0;
    margin-left: auto;
    color: var(--text-muted);
  }
</style>
