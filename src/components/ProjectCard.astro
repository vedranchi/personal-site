---
import WoodPanel from './WoodPanel.astro';
import PixelButton from './PixelButton.astro';

export interface Project {
  name: string;
  description: string;
  url: string;
  homepage: string | null;
  language: string | null;
  topics: string[];
  stars: number;
  updatedAt: string;
}
interface Props {
  project: Project;
}
const { project }: Props = Astro.props;

// A few GitHub-ish language colors; unknown languages fall back to a neutral tone.
const LANG_COLORS: Record<string, string> = {
  Python: '#3572a5',
  JavaScript: '#f1e05a',
  TypeScript: '#3178c6',
  Astro: '#ff5a03',
  HTML: '#e34c26',
  CSS: '#563d7c',
  Shell: '#89e051',
  'C++': '#f34b7d',
  C: '#555555',
  Java: '#b07219',
  Go: '#00add8',
  Rust: '#dea584',
  Vue: '#41b883',
  Svelte: '#ff3e00',
};
const langColor = project.language ? (LANG_COLORS[project.language] ?? '#9c8a6b') : null;

const updated = new Date(project.updatedAt).toLocaleDateString('en-US', {
  month: 'short',
  year: 'numeric',
});
---

<WoodPanel as="article" class="project">
  <h3 class="project-name">
    <a href={project.url} target="_blank" rel="noopener">{project.name}</a>
  </h3>

  {project.description && <p class="project-desc">{project.description}</p>}

  {
    project.topics.length > 0 && (
      <ul class="topics">
        {project.topics.slice(0, 6).map((t) => (
          <li class="topic pixel-label">{t}</li>
        ))}
      </ul>
    )
  }

  <div class="project-meta pixel-label">
    {
      project.language && (
        <span class="lang">
          <span class="lang-dot" style={`background:${langColor}`} aria-hidden="true" />
          {project.language}
        </span>
      )
    }
    {project.stars > 0 && <span class="stars">★ {project.stars}</span>}
    <span class="updated">Updated {updated}</span>
  </div>

  <div class="project-actions">
    <PixelButton href={project.url}>Code</PixelButton>
    {
      project.homepage && (
        <PixelButton href={project.homepage} variant="ghost">
          Live
        </PixelButton>
      )
    }
  </div>
</WoodPanel>

<style>
  .project {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    height: 100%;
  }
  .project-name {
    margin: 0;
    font-size: 1.25rem;
    word-break: break-word;
  }
  .project-name a {
    text-decoration: none;
    color: var(--text);
  }
  .project-name a:hover {
    color: var(--link);
  }
  .project-desc {
    margin: 0;
    color: var(--text-muted);
    flex: 1;
  }
  .topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .topic {
    background: var(--surface-2);
    border: 2px solid var(--frame);
    border-radius: 2px;
    padding: 0.15rem 0.4rem;
    color: var(--text-muted);
  }
  .project-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-muted);
  }
  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .lang-dot {
    width: 0.7rem;
    height: 0.7rem;
    border: 2px solid var(--frame-dark);
    border-radius: 50%;
  }
  .stars {
    color: var(--highlight);
  }
  .project-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }
</style>
