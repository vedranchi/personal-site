---
// Day/night toggle. The no-FOUC init script lives in BaseLayout's <head>.
---

<button
  id="theme-toggle"
  class="theme-toggle"
  aria-label="Toggle day / night"
  title="Toggle day / night"
>
  <span class="icon icon-day" aria-hidden="true">☀️</span>
  <span class="icon icon-night" aria-hidden="true">🌙</span>
</button>

<style>
  .theme-toggle {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    padding: 0;
    font-size: 1.1rem;
    background: var(--surface);
    color: var(--text);
    border: 3px solid var(--frame-dark);
    border-radius: var(--radius);
    box-shadow: 2px 2px 0 0 var(--frame-dark);
    cursor: pointer;
  }
  .theme-toggle:active {
    transform: translate(2px, 2px);
    box-shadow: 0 0 0 0 var(--frame-dark);
  }
  .icon {
    line-height: 1;
  }
</style>

<style is:global>
  :root[data-theme='dark'] .theme-toggle .icon-day {
    display: none;
  }
  :root:not([data-theme='dark']) .theme-toggle .icon-night {
    display: none;
  }
</style>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    try {
      localStorage.setItem('theme', next);
    } catch (e) {
      /* ignore storage errors (private mode) */
    }
  });
</script>
